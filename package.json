{
  "name": "annonce-immo-locator",
  "version": "1.0.0",
  "description": "Chrome Extension for extracting real estate data from Leboncoin and cross-referencing with ADEME",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "build": "node scripts/build.js"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.48.0",
    "vitest": "^2.1.0"
  }
}
